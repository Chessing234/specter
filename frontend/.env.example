# SPECTER FastAPI (browser + server-side fetch). Default: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket base (no path). Default: ws://localhost:8000 — use wss:// on production
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Optional: same-origin /api/* rewrite target (see next.config.js)
# API_PROXY_TARGET=http://localhost:8000
