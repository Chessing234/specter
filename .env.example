# LLM API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# AWS (for Aurora DSQL, optional for local dev)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Database
DATABASE_URL=postgresql://specter:specter@localhost:5432/specter
# For Aurora DSQL production:
# DATABASE_URL=postgresql://...aurora-dsql...

# Redis
REDIS_URL=redis://localhost:6379/0

# Application
LOG_LEVEL=INFO
SECRET_KEY=generate-a-secure-random-key-here
ENVIRONMENT=development

# Splunk (optional)
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_USERNAME=admin
SPLUNK_PASSWORD=...

# Sola Security (optional)
SOLA_API_KEY=...
SOLA_BASE_URL=https://api.sola.security

# SANS SIFT (optional)
SIFT_HOST=localhost
SIFT_PORT=22
SIFT_USERNAME=sansforensics
